# PolicyPal runtime config — loaded automatically by docker compose.
# ⚠️  Put your real key below. Do NOT commit this file.

# --- API key ---
OPENROUTER_API_KEY=
COST_INPUT_PER_1M=0.2
COST_OUTPUT_PER_1M=1.25

# --- LLM provider ---
LLM_PROVIDER=openrouter

# --- Chat model (any OpenRouter model id) ---
OPENROUTER_MODEL=openai/gpt-5.4-nano
TEMPERATURE=0
TOP_P=1
SEED=114514

# --- Embeddings (OpenRouter serves these too; ids are provider-prefixed) ---
EMBEDDING_PROVIDER=openrouter
EMBEDDING_MODEL=qwen/qwen3-embedding-8b
# qwen3-embedding-8b is natively 4096-dim; request 1536 via Matryoshka (MRL).
EMBEDDING_DIM=1536

# --- pgvector ---
STORE_REBUILD=1